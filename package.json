{
  "name": "@flagdrop/evaluator",
  "version": "2.0.0",
  "description": "Lightweight flag evaluation library for FlagDrop config files",
  "keywords": [
    "feature-flags",
    "feature-toggle",
    "flagdrop",
    "rollout",
    "targeting",
    "openfeature"
  ],
  "homepage": "https://github.com/flagdrop-io/evaluator#readme",
  "bugs": {
    "url": "https://github.com/flagdrop-io/evaluator/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flagdrop-io/evaluator.git"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "murmurhash3js": "^3.0.1"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "license": "MIT"
}
